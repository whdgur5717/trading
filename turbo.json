{
  "$schema": "https://turborepo.com/schema.json",
  "globalEnv": ["APP_ORIGIN"],
  "tasks": {
    "front#build": {
      "dependsOn": ["type-check"],
      "outputs": [".open-next/**", "!.open-next/**/node_modules/**"]
    },
    "back#build": {
      "dependsOn": ["type-check"],
      "outputs": ["dist/**"]
    },
    "@trading/api-client#build": {
      "dependsOn": ["type-check"],
      "outputs": []
    },
    "type-check": {
      "outputs": []
    },
    "lint": {
      "outputs": []
    },
    "test": {
      "outputs": []
    },
    "format": {
      "outputs": []
    }
  }
}
