{{#if usesHttp}}{{#if usesSse}}import { ApiSchemaError, ApiUnexpectedStatusError, api, apiBaseUrl } from "../api"{{else}}import { ApiSchemaError, ApiUnexpectedStatusError, api } from "../api"{{/if}}{{else}}import { apiBaseUrl } from "../api"{{/if}}
{{#if usesHttp}}import { ResultAsync, err, ok, type Result } from "neverthrow"
{{/if}}
{{#if schemaImports.length}}
import {
{{#each schemaImports}}
  {{this}},
{{/each}}
} from "./schemas"
{{/if}}
{{#if schemaExports.length}}
export {
{{#each schemaExports}}
  {{this}},
{{/each}}
} from "./schemas"
{{/if}}
{{#if typeExports.length}}
export type {
{{#each typeExports}}
  {{this}},
{{/each}}
} from "./schemas"
{{/if}}

{{#each operations}}
{{#if hasParams}}
export type {{paramsTypeName}} = {{{paramsTypeExpression}}}

{{/if}}
{{#if isSse}}
{{#if failureResponses.length}}
export type {{failureTypeName}} =
{{#each failureResponses}}
  | { status: {{statusTypeExpression}}; body: {{typeName}} }
{{/each}}

{{/if}}
/**
{{#each jsDocLines}}
 * {{{this}}}
{{/each}}
 */
export function {{functionName}}({{#if hasParams}}params: {{paramsTypeName}}{{/if}}): EventSource {
  const searchParams = new URLSearchParams()
{{#each sseQueryLines}}
  {{{this}}}
{{/each}}
  const queryString = searchParams.toString()

  return new EventSource(apiBaseUrl + {{{eventSourcePathExpression}}} + (queryString ? `?${queryString}` : ""))
}
{{else}}
export type {{successTypeName}} =
{{#if successResponses.length}}
{{#each successResponses}}
  | { status: {{statusTypeExpression}}; body: {{typeName}} }
{{/each}}
{{else}}
  never
{{/if}}

export type {{failureTypeName}} =
{{#if failureResponses.length}}
{{#each failureResponses}}
  | { status: {{statusTypeExpression}}; body: {{typeName}} }
{{/each}}
{{else}}
  never
{{/if}}

/**
{{#each jsDocLines}}
 * {{{this}}}
{{/each}}
 */
export function {{functionName}}({{#if hasParams}}params: {{paramsTypeName}}{{/if}}): ResultAsync<{{successTypeName}}, {{failureTypeName}}> {
{{#if hasResponseBody}}
  return new ResultAsync(
    (async (): Promise<Result<{{successTypeName}}, {{failureTypeName}}>> => {
      const response = await api.{{method}}({{{pathExpression}}}{{#if kyOptionsExpression}}, {{{kyOptionsExpression}}}{{/if}})
      const body: unknown = await response.json()

      switch (response.status) {
{{#each successResponses}}
        {{switchLabel}} {
          const result = {{schemaName}}.safeParse(body)

          if (!result.success) {
            throw new ApiSchemaError({
              status: response.status,
              schemaName: "{{schemaName}}",
              body,
              zodError: result.error,
            })
          }

          const value: {{../successTypeName}} = {
            status: {{statusValueExpression}},
            body: result.data,
          }

          return ok(value)
        }
{{/each}}
{{#each failureResponses}}
        {{switchLabel}} {
          const result = {{schemaName}}.safeParse(body)

          if (!result.success) {
            throw new ApiSchemaError({
              status: response.status,
              schemaName: "{{schemaName}}",
              body,
              zodError: result.error,
            })
          }

          const value: {{../failureTypeName}} = {
            status: {{statusValueExpression}},
            body: result.data,
          }

          return err(value)
        }
{{/each}}
      }

      throw new ApiUnexpectedStatusError(response.status, body)
    })()
  )
{{else}}
  return new ResultAsync(
    (async (): Promise<Result<{{successTypeName}}, {{failureTypeName}}>> => {
      await api.{{method}}({{{pathExpression}}}{{#if kyOptionsExpression}}, {{{kyOptionsExpression}}}{{/if}})
      throw new Error("Response body schema is not defined")
    })()
  )
{{/if}}
}
{{/if}}

{{/each}}
