{
  "name": "back",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write . --ignore-path ../.prettierignore",
    "start": "NODE_ENV=development nest start",
    "start:dev": "NODE_ENV=development nest start --watch",
    "start:mock": "NODE_ENV=development nest start --path tsconfig.json --sourceRoot . --entryFile scripts/dev-mock --watch",
    "start:debug": "NODE_ENV=development nest start --debug --watch",
    "start:prod": "NODE_ENV=production node dist/main.js",
    "lint": "eslint --fix . --max-warnings 0",
    "test": "vitest run src",
    "test:watch": "vitest src",
    "test:cov": "vitest run src --coverage",
    "test:debug": "vitest --inspect-brk --run src",
    "test:e2e": "vitest run test/e2e --fileParallelism=false",
    "lint:staged": "eslint --fix --max-warnings 0",
    "type-check": "tsc --noEmit --incremental false"
  },
  "dependencies": {
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.0.1",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/swagger": "^11.4.3",
    "es-toolkit": "^1.46.1",
    "nestjs-zod": "^5.4.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "swagger-ui-express": "^5.0.1",
    "ws": "^8.20.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@swc/core": "^1.15.3",
    "@types/express": "^5.0.0",
    "@types/node": "^24.0.0",
    "@types/ws": "^8.18.1",
    "@vitest/coverage-v8": "^4.1.6",
    "eventsource": "^4.1.0",
    "handlebars": "^4.7.9",
    "msw": "^2.14.6",
    "orval": "^8.10.0",
    "source-map-support": "^0.5.21",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "unplugin-swc": "^1.5.7",
    "vitest": "^4.0.15"
  }
}
